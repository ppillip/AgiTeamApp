# AgiTeamApp Docker deployment example.
# Copy to system/AgiTeamApp/.env for local compose use.

AGITEAMAPP_FRONTEND_PORT=1420
AGITEAMAPP_BACKEND_PORT=18000
AGITEAMAPP_DB_PORT=15432

POSTGRES_DB=agiteamapp
POSTGRES_USER=agiteamapp
POSTGRES_PASSWORD=change-me-local-only

WEBGUI_DATABASE_URL=postgresql+psycopg://agiteamapp:change-me-local-only@db:5432/agiteamapp
WEBGUI_PROJECT_ID=Panthea
WEBGUI_PROJECTS_BASE_DIR=/projects
WEBGUI_PROJECT_ROOTS_JSON={"Panthea":"/projects/Panthea"}
WEBGUI_AGITEAM_LOGS_SUBDIR=.agiteam/logs
WEBGUI_ARTIFACTS_ROOT=/projects/Panthea/documents/products/AgiTeamApp

# Until the host cmux adapter is split out, container API must not call cmux directly.
WEBGUI_ENABLE_BACKGROUND=false
