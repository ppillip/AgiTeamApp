# AgiTeamApp WebGUI Backend 환경설정 예시 (DS-60 §DV-50 설정 인계)
# 복사: cp .env.example .env

# PostgreSQL DSN (DS-30 확정 스택). SQLAlchemy + psycopg(async) 형식.
WEBGUI_DATABASE_URL=postgresql+psycopg://webgui:webgui@localhost:5432/webgui

# 모니터 대상 프로젝트 식별자 (방/메시지 귀속 키)
WEBGUI_PROJECT_ID=AgiTeamApp

# 산출물 allowlist 루트 (절대경로). 미설정 시 레포 기준 documents/products/AgiTeamApp 자동 추정
# WEBGUI_ARTIFACTS_ROOT=/abs/path/to/Panthea/documents/products/AgiTeamApp

# 일반 WebGUI API bearer 토큰 (미설정 시 로컬 dev 모드: 인증 생략)
# WEBGUI_API_TOKEN=change-me

# collector 전용 토큰 (WG-CHAT-05/06 내부 API). 미설정 시 dev 모드 허용
# WEBGUI_COLLECTOR_TOKEN=change-me-collector

# cmux 실행 파일 경로 (PATH 비의존 — 절대경로)
WEBGUI_CMUX_BIN=/Applications/cmux.app/Contents/Resources/bin/cmux

# 디스커버리/수집 (2026-06-07 보강)
# project_id -> 루트. 미설정 시 projects_base_dir/<project_id> (기본 = 레포의 부모, 예 ~/Projects)
# WEBGUI_PROJECTS_BASE_DIR=/Users/me/Projects
# WEBGUI_PROJECT_ROOTS_JSON={"Panthea":"/Users/me/Projects/Panthea"}
WEBGUI_AGITEAM_LOGS_SUBDIR=.agiteam/logs
WEBGUI_DISCOVERY_POLL_SECONDS=5
WEBGUI_LOGTAIL_POLL_SECONDS=2
WEBGUI_ENABLE_BACKGROUND=true

# 파일/렌더 제한
WEBGUI_MAX_INLINE_BYTES=1048576
WEBGUI_MAX_STREAM_BYTES=52428800
WEBGUI_MAX_TREE_NODES=2000
WEBGUI_MAX_TREE_DEPTH=6
WEBGUI_RENDER_TIMEOUT_SECONDS=30
