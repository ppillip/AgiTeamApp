# AgiTeamApp Python/Rust parity environment example.
# Copy to .env.equiv for local overrides. No real secrets here.

POSTGRES_DB=agiteamapp
POSTGRES_USER=agiteamapp
POSTGRES_PASSWORD=change-me-equiv-local-only
# Host port for the isolated test Postgres. Keep production/local 15432 untouched.
AGITEAMAPP_EQUIV_DB_PORT=15433

AGITEAMAPP_EQUIV_PY_DB=agiteamapp_equiv_py
AGITEAMAPP_EQUIV_RS_DB=agiteamapp_equiv_rs
AGITEAMAPP_EQUIV_TEMPLATE_DB=agiteamapp_equiv_template

AGITEAMAPP_EQUIV_PY_PORT=18080
AGITEAMAPP_EQUIV_RS_PORT=18081

WEBGUI_PROJECT_ID=Panthea
WEBGUI_PROJECTS_BASE_DIR=/projects
WEBGUI_PROJECT_ROOTS_JSON='{"Panthea":"/projects/Panthea"}'
# RV-65: Python also needs background discovery warm-up against fake cmux.
WEBGUI_ENABLE_BACKGROUND=true
WEBGUI_ARTIFACT_WATCHER_ENABLED=false
WEBGUI_AGITEAM_LOGS_SUBDIR=.agiteam/equiv-empty-logs

AGITEAMAPP_PROJECT_ID=Panthea
AGITEAMAPP_PROJECTS_BASE=/projects
AGITEAMAPP_MUX=cmux
AGITEAMAPP_ARTIFACT_WATCHER_ENABLED=false

AGITEAMAPP_EQUIV_FAKE_MUX_LOG=/tmp/agiteamapp-equiv/fake-mux.jsonl
