{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AgiTeamApp",
  "version": "0.1.0",
  "identifier": "com.panthea.agiteamapp",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "VITE_API_BASE=http://127.0.0.1:8000 VITE_WS_BASE=ws://127.0.0.1:8000 pnpm dev",
    "beforeBuildCommand": "VITE_API_BASE=http://127.0.0.1:8000 VITE_WS_BASE=ws://127.0.0.1:8000 pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "AgiTeamApp",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
